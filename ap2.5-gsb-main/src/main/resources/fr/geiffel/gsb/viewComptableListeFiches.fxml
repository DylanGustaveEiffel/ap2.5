<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane
        prefHeight="552.0" prefWidth="985.0"
        xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="fr.geiffel.gsb.controllers.comptable.ComptableListeFichesController">

    <Pane layoutX="-30.0" layoutY="-83.0" prefHeight="200.0" prefWidth="200.0" />
    <ImageView fitHeight="174.0" fitWidth="233.0" layoutX="701.0" layoutY="45.0" pickOnBounds="true" preserveRatio="true">
        <Image url="@../../../img/gsb.png" />
    </ImageView>
    <Button fx:id="btnOuvrirFiche" layoutX="664.0" layoutY="249.0" mnemonicParsing="false" onAction="#buttonOuvrirFicheClick" text="Ouvrir fiche sélectionnée" textAlignment="CENTER">
        <font>
            <Font size="25.0" />
        </font>
    </Button>
    <fx:include source="previous-button.fxml" />
    <TableView fx:id="tableListeFiches" layoutX="29.0" layoutY="65.0" prefHeight="400.0" prefWidth="575.0">
        <columns>
            <TableColumn fx:id="colIdFiche" prefWidth="75.0" text="Code" />
            <TableColumn fx:id="colNomVisiteur" prefWidth="172.0" text="Visiteur" />
            <TableColumn fx:id="colMoisFiche" editable="false" prefWidth="153.0" sortable="false" text="Mois" />
            <TableColumn fx:id="colEtatFiche" prefWidth="174.0" text="Etat" />
        </columns>
    </TableView>
</AnchorPane>
